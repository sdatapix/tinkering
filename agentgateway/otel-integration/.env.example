# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and customise before running docker-compose up
# ─────────────────────────────────────────────────────────────────────────────

# Where the OTel Collector exports logs + traces.
# Default: the bundled Jaeger service on the Docker network.
# Override to point at an external backend:
#   Grafana OTLP:   https://otlp-gateway-prod-us-east-0.grafana.net:443
#   Honeycomb:      https://api.honeycomb.io:443
#   External Jaeger: http://<host>:4317
OTEL_BACKEND_ENDPOINT=http://jaeger:4317

# Set to false when connecting to a TLS-enabled backend
OTEL_COLLECTOR_INSECURE=true

# Stamped onto every log record and span as deployment.environment
DEPLOYMENT_ENVIRONMENT=development

# Optional: bearer token for authenticated OTLP backends
# OTEL_BACKEND_TOKEN=
